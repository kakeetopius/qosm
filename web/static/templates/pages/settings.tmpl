{{ define "content" }}
<main class="flex-1 p-8 space-y-8">


	<!-- ================= INTERFACE SETTINGS ================= -->
	<section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6 space-y-6">

		<h3 class="text-lg font-semibold">Interface Settings</h3>

		<p class="text-sm text-zinc-400">
			Configure QoS for individual network interfaces.
		</p>

		<div class="divide-y divide-zinc-800">

			{{ range .Ifaces }}

			<div class="flex items-center justify-between py-4" id="iface-{{ .Name }}">
				<p class="font-medium text-zinc-100">
					{{ .Name }}
				</p>
				<!-- Status + Action -->
				<div class="flex items-center gap-8">
					{{ if .QoSEnabled }}
					<div class="flex items-center gap-2 text-sm text-green-400">
						<span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
						<span>Enabled</span>
					</div>
					{{ else }}
					<div class="flex items-center gap-2 text-sm text-red-400">
						<span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
						<span>Disabled</span>
					</div>
					{{ end }}
					<button class="text-sm font-medium text-blue-400 hover:text-blue-100 transition"
						hx-get="/settings/interfaces/{{ .Name }}" hx-target="#modal" hx-swap="innerHTML">
						Configure
					</button>
				</div>
			</div>

			{{ end }}
		</div>

	</section>
	<!-- ================= DNS SETTINGS ================= -->
	<form hx-post="/settings/dns/save" hx-swap="none">
		<section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6 space-y-6">

			<h3 class="text-lg font-semibold">DNS Settings</h3>

			<!-- Primary DNS -->
			<div>
				<label class="block text-sm text-zinc-300 mb-2">
					Primary DNS
				</label>

				<input name="primary_dns" type="text" value="{{ .Settings.PrimaryDNS }}"
					class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2">
			</div>

			<!-- DNS Override -->
			<div class="flex items-center justify-between">
				<div>
					<p class="font-medium">DNS Override</p>
					<p class="text-sm text-zinc-400">
						Force custom DNS resolution
					</p>
				</div>

				<input name="dns_override" type="checkbox" class="w-5 h-5 accent-blue-600" {{ if .Settings.DNSOverride
					}}checked{{ end }}>
			</div>

			<div class="flex justify-end pt-2">
				<button type="submit"
					class="bg-blue-950 hover:bg-blue-900 border border-blue-900 transition px-5 py-2 rounded-lg font-medium text-blue-200">
					Save
				</button>
			</div>

		</section>
	</form>

	<!-- ================= SECURITY SETTINGS ================= -->
	<form hx-post="/settings/security/save" hx-swap="none">
		<section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6 space-y-6">

			<h3 class="text-lg font-semibold">Security Settings</h3>


			<!-- Session Timeout -->
			<div>
				<label class="block text-sm text-zinc-300 mb-2">
					Session Timeout (minutes)
				</label>

				<input name="session_timeout" type="number" value="{{ .Settings.SessionTimeout }}"
					class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2">
			</div>

			<div class="flex justify-end pt-2">
				<button type="submit"
					class="bg-blue-950 hover:bg-blue-900 border border-blue-900 transition px-5 py-2 rounded-lg font-medium text-blue-200">
					Save
				</button>
			</div>

		</section>
	</form>

	<!-- ================= MODAL PLACEHOLDER ================= -->
	<div id="modal"></div>

</main>
{{ end }}
