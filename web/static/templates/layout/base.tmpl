{{ define "base.tmpl" }}
<!DOCTYPE html>
<html>

{{ block "meta" . }} {{ end }}

<body class="min-h-screen bg-zinc-950 text-zinc-100">
	<div id="toast-container" class="fixed top-4 right-4 z-50 space-y-2">
	</div>

	<div class="flex min-h-screen">
		<!-- Sidebar -->
		{{ block "sidebar" . }} {{ end }}

		<!-- Main -->
		<div class="flex-1 flex flex-col">
			{{ block "topbar" . }} {{ end }}

			{{ block "content" . }} {{ end }}
		</div>


	</div>
</body>

</html>
{{ end }}
